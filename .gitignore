*.egg-info/

# C / build
build/
*.o
*.obj
*.exe
*.dll
*.a

# Database & data
server/data/*.db
server/data/*.seed
*.sqlite
*.sqlite3
# Package đã publish (chứa payload.enc) + keypair ký do Dashboard sinh khi đóng gói
server/data/packages/
