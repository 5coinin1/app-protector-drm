# Sao chép thành .env và đổi giá trị cho production.
# JWT_SECRET: chuỗi ngẫu nhiên dài, BÍ MẬT (đừng commit .env thật).
# Nếu KHÔNG đặt (hoặc để placeholder), server tự sinh secret ngẫu nhiên bền và lưu vào
# data/jwt_secret.key (gitignore) — vẫn an toàn, không dùng secret mặc định.
# JWT_SECRET=dat-chuoi-ngau-nhien-that-dai-o-day
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# Rate-limit đăng nhập (chống brute-force)
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=300

# Admin khởi tạo lần đầu (chỉ tạo nếu DB chưa có user nào)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345

# DATABASE_URL=sqlite:///./data/app.db
